. **# 0.3 Helper programs
. *------------------------------------------------------------------------------*
. 
. capture program drop aju_mean_table

. program define aju_mean_table
  1.     syntax anything, SHEET(string) MODULE(string) [XLSX(string) GRAPH(string) TITLE(string) GAP]
  2. 
.     tempfile out
  3.     tempname memhold
  4.     postfile `memhold' str80 module str80 variable str160 label ///
>         long n double mean sd min p25 p50 p75 max gap using `out', replace
  5. 
.     local clean_module "`module'"
  6.     local rawvars `anything'
  7. 
.     foreach v of local rawvars {
  8.         capture confirm numeric variable `v'
  9.         if !_rc {
 10.             quietly count if !missing(`v')
 11.             local n = r(N)
 12.             local vlab : variable label `v'
 13.             if `"`vlab'"' == "" local vlab "`v'"
 14.             local vlab = substr(`"`vlab'"', 1, 160)
 15. 
.             if `n' > 0 {
 16.                 quietly summarize `v', detail
 17.                 local mean = r(mean)
 18.                 local sd   = r(sd)
 19.                 local min  = r(min)
 20.                 local p25  = r(p25)
 21.                 local p50  = r(p50)
 22.                 local p75  = r(p75)
 23.                 local max  = r(max)
 24.                 local gapval = .
 25.                 if "`gap'" != "" & `mean' >= 0 & `mean' <= 1 local gapval = 1 - `mean'
 26.             }
 27.             else {
 28.                 local mean   = .
 29.                 local sd     = .
 30.                 local min    = .
 31.                 local p25    = .
 32.                 local p50    = .
 33.                 local p75    = .
 34.                 local max    = .
 35.                 local gapval = .
 36.             }
 37. 
.             post `memhold' (`"`clean_module'"') (`"`v'"') (`"`vlab'"') ///
>                 (`n') (`mean') (`sd') (`min') (`p25') (`p50') (`p75') (`max') (`gapval')
 38.         }
 39.     }
 40.     postclose `memhold'
 41. 
.     local outxlsx "${AJU_EXEC_XLSX}"
 42.     if `"`xlsx'"' != "" local outxlsx `"`xlsx'"'
 43. 
.     preserve
 44.         use `out', clear
 45.         drop if n == 0
 46.         order module variable label n mean sd min p25 p50 p75 max gap
 47.         if "`gap'" == "" drop gap
 48.         export excel using `"`outxlsx'"', sheet("`sheet'", replace) firstrow(variables)
 49. 
.         if `"`graph'"' != "" {
 50.             quietly count if !missing(mean)
 51.             if r(N) > 0 {
 52.                 local graphname = strtoname("`graph'")
 53.                 local graphname = substr("`graphname'", 1, 32)
 54.                 local graphtitle `"`title'"'
 55.                 if `"`graphtitle'"' == "" local graphtitle "`sheet'"
 56. 
.                 graph hbar mean if !missing(mean), ///
>                     over(label, sort(mean) descending label(labsize(vsmall))) ///
>                     ytitle("Share / mean") ///
>                     title(`"`graphtitle'"', size(medsmall)) ///
>                     name(`graphname', replace)
 57. 
.                 graph export "${AJU_FIG_DIR}/`graph'.png", replace width(2400)
 58.                 graph export "${AJU_FIG_DIR}/`graph'.pdf", replace
 59.             }
 60.         }
 61.     restore
 62. end

. 
. capture program drop aju_tab_numeric_all

. program define aju_tab_numeric_all
  1.     syntax anything, SHEET(string)
  2. 
.     tempfile out
  3.     tempname memhold
  4.     postfile `memhold' str30 module str80 variable str200 label ///
>         long n n_missing double mean sd min p25 p50 p75 max using `out', replace
  5. 
.     local rawvars `anything'
  6.     foreach v of local rawvars {
  7.         capture confirm numeric variable `v'
  8.         if !_rc {
  9.             quietly count
 10.             local Ntotal = r(N)
 11.             quietly count if !missing(`v')
 12.             local n = r(N)
 13.             local nmiss = `Ntotal' - `n'
 14. 
.             local module "Other"
 15.             if regexm("`v'","^m0_") local module "M0 Geography/metadata"
 16.             if regexm("`v'","^m1_") local module "M1 Respondent profile"
 17.             if regexm("`v'","^m2_") local module "M2 Institutional setup"
 18.             if regexm("`v'","^m3_") local module "M3 Caseload"
 19.             if regexm("`v'","^m4_") local module "M4 Legal knowledge"
 20.             if regexm("`v'","^m5_") local module "M5 ADR/mediation"
 21.             if regexm("`v'","^m6_") local module "M6 Referrals"
 22.             if regexm("`v'","^m7_") local module "M7 Records"
 23.             if regexm("`v'","^m8_") local module "M8 Committee"
 24.             if regexm("`v'","^m9_") local module "M9 Legitimacy"
 25.             if regexm("`v'","^m10_") local module "M10 Safeguards"
 26.             if regexm("`v'","^m11_") local module "M11 Reintegration"
 27.             if regexm("`v'","^idx_") local module "Indices"
 28.             if regexm("`v'","^flag_") local module "QA flags"
 29. 
.             local vlab : variable label `v'
 30.             if `"`vlab'"' == "" local vlab "`v'"
 31.             local vlab = substr(`"`vlab'"', 1, 200)
 32. 
.             if `n' > 0 {
 33.                 quietly summarize `v', detail
 34.                 post `memhold' (`"`module'"') (`"`v'"') (`"`vlab'"') ///
>                     (`n') (`nmiss') (r(mean)) (r(sd)) (r(min)) (r(p25)) (r(p50)) (r(p75)) (r(max))
 35.             }
 36.             else {
 37.                 post `memhold' (`"`module'"') (`"`v'"') (`"`vlab'"') ///
>                     (`n') (`nmiss') (.) (.) (.) (.) (.) (.) (.)
 38.             }
 39.         }
 40.     }
 41.     postclose `memhold'
 42. 
.     preserve
 43.         use `out', clear
 44.         sort module variable
 45.         export excel using "${AJU_ITEMS_XLSX}", sheet("`sheet'", replace) firstrow(variables)
 46.     restore
 47. end

