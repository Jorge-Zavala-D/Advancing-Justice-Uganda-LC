. capture program drop aju_module_of_var

. program define aju_module_of_var, rclass
  1.     args v
  2.     local module "Other"
  3.     if regexm("`v'","^m0_") local module "M0 Geography/metadata"
  4.     if regexm("`v'","^m1_") local module "M1 Respondent profile"
  5.     if regexm("`v'","^m2_") local module "M2 Institutional setup"
  6.     if regexm("`v'","^m3_") local module "M3 Caseload"
  7.     if regexm("`v'","^m4_") local module "M4 Legal knowledge"
  8.     if regexm("`v'","^m5_") local module "M5 ADR/mediation"
  9.     if regexm("`v'","^m6_") local module "M6 Referrals"
 10.     if regexm("`v'","^m7_") local module "M7 Records"
 11.     if regexm("`v'","^m8_") local module "M8 Committee"
 12.     if regexm("`v'","^m9_") local module "M9 Legitimacy"
 13.     if regexm("`v'","^m10_") local module "M10 Safeguards"
 14.     if regexm("`v'","^m11_") local module "M11 Reintegration"
 15.     if regexm("`v'","^idx_") local module "Indices"
 16.     if regexm("`v'","^flag_") local module "QA flags"
 17.     return local module "`module'"
 18. end

