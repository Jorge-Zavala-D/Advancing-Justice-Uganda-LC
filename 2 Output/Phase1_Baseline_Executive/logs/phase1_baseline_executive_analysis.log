. capture program drop aju_tab_categorical_all

. program define aju_tab_categorical_all
  1.     syntax anything, SHEET(string) [MAXLEVELS(integer 25)]
  2. 
.     tempfile out
  3.     tempname memhold
  4.     postfile `memhold' str30 module str80 variable str200 label ///
>         str40 value str200 value_label long n double percent using `out', replace
  5. 
.     local rawvars `anything'
  6.     foreach v of local rawvars {
  7.         capture confirm numeric variable `v'
  8.         if !_rc {
  9.             quietly levelsof `v' if !missing(`v'), local(levels)
 10.             local k : word count `levels'
 11. 
.             if `k' > 0 & `k' <= `maxlevels' {
 12.                 quietly count if !missing(`v')
 13.                 local denom = r(N)
 14. 
.                 local module "Other"
 15.                 if regexm("`v'","^m0_") local module "M0 Geography/metadata"
 16.                 if regexm("`v'","^m1_") local module "M1 Respondent profile"
 17.                 if regexm("`v'","^m2_") local module "M2 Institutional setup"
 18.                 if regexm("`v'","^m3_") local module "M3 Caseload"
 19.                 if regexm("`v'","^m4_") local module "M4 Legal knowledge"
 20.                 if regexm("`v'","^m5_") local module "M5 ADR/mediation"
 21.                 if regexm("`v'","^m6_") local module "M6 Referrals"
 22.                 if regexm("`v'","^m7_") local module "M7 Records"
 23.                 if regexm("`v'","^m8_") local module "M8 Committee"
 24.                 if regexm("`v'","^m9_") local module "M9 Legitimacy"
 25.                 if regexm("`v'","^m10_") local module "M10 Safeguards"
 26.                 if regexm("`v'","^m11_") local module "M11 Reintegration"
 27.                 if regexm("`v'","^idx_") local module "Indices"
 28.                 if regexm("`v'","^flag_") local module "QA flags"
 29. 
.                 local vlab : variable label `v'
 30.                 if `"`vlab'"' == "" local vlab "`v'"
 31.                 local vlab = substr(`"`vlab'"', 1, 200)
 32. 
.                 local vallab : value label `v'
 33. 
.                 foreach lev of local levels {
 34.                     quietly count if `v' == `lev'
 35.                     local n = r(N)
 36.                     local pct = 100 * `n' / `denom'
 37. 
.                     local levlabel "`lev'"
 38.                     if `"`vallab'"' != "" {
 39.                         capture local levlabel : label `vallab' `lev'
 40.                         if _rc local levlabel "`lev'"
 41.                     }
 42.                     local levlabel = substr(`"`levlabel'"', 1, 200)
 43. 
.                     post `memhold' (`"`module'"') (`"`v'"') (`"`vlab'"') ///
>                         (`"`lev'"') (`"`levlabel'"') (`n') (`pct')
 44.                 }
 45.             }
 46.         }
 47.     }
 48.     postclose `memhold'
 49. 
.     preserve
 50.         use `out', clear
 51.         sort module variable value
 52.         export excel using "${AJU_ITEMS_XLSX}", sheet("`sheet'", replace) firstrow(variables)
 53.     restore
 54. end

