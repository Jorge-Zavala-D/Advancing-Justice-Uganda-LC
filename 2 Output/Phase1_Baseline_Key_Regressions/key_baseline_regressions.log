. local order = 0

. foreach y of local outcomes {
  2.     local ++order
  3.     local ylab `"`label`order''"'
  4. 
.     quietly summarize `y' if p1_admin_previously_contacted == 0, meanonly
  5.     local mean0 = r(mean)
  6.     quietly summarize `y' if p1_admin_previously_contacted == 1, meanonly
  7.     local mean1 = r(mean)
  8.     local rawdiff = `mean1' - `mean0'
  9. 
.     display as text _newline "Outcome `order': `ylab'"
 10.     noisily regress `y' i.p1_admin_previously_contacted i.regression_distr
> ict_id, ///
>         vce(cluster survey_village_id)
 11. 
.     local b = _b[1.p1_admin_previously_contacted]
 12.     local se = _se[1.p1_admin_previously_contacted]
 13.     local p = 2 * ttail(e(df_r), abs(`b' / `se'))
 14.     local crit = invttail(e(df_r), .025)
 15.     local lo = `b' - `crit' * `se'
 16.     local hi = `b' + `crit' * `se'
 17.     local n = e(N)
 18.     local clusters = e(N_clust)
 19.     local r2 = e(r2)
 20. 
.     display as result "Previously contacted coefficient: " %7.3f `b' ///
>         " (SE " %7.3f `se' ", p=" %6.3f `p' ")"
 21.     display as result "95% CI: [" %7.3f `lo' ", " %7.3f `hi' "]"
 22. 
.     post `regpost' (`order') (`"`y'"') (`"`ylab'"') (`n') (`clusters') ///
>         (`mean0') (`mean1') (`rawdiff') (`b') (`se') (`p') (`lo') (`hi') (`r2
> ')
 23. }

